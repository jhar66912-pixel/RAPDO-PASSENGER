rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'mobile', 'role', 'createdAt']) &&
        data.uid is string &&
        data.name is string && data.name.size() <= 100 &&
        data.mobile is string && data.mobile.size() <= 15 &&
        data.role is string && (data.role == 'customer' || data.role == 'rider' || data.role == 'admin') &&
        data.createdAt is number;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['bookingId', 'customerId', 'customerName', 'customerMobile', 'bookingType', 'pickupName', 'dropName', 'status', 'rideOtp', 'createdAt']) &&
        data.bookingId is string && data.bookingId.size() <= 128 &&
        data.customerId is string && data.customerId.size() <= 128 &&
        data.customerName is string && data.customerName.size() <= 100 &&
        data.customerMobile is string && data.customerMobile.size() <= 15 &&
        data.bookingType is string && data.bookingType.size() <= 20 &&
        (!('selectedRouteId' in data.keys()) || data.selectedRouteId == null || (data.selectedRouteId is string && data.selectedRouteId.size() <= 128)) &&
        data.pickupName is string && data.pickupName.size() <= 200 &&
        data.dropName is string && data.dropName.size() <= 200 &&
        (!('fare' in data.keys()) || data.fare == null || data.fare is number) &&
        (!('distanceKm' in data.keys()) || data.distanceKm == null || data.distanceKm is number) &&
        data.status is string && data.status.size() <= 20 &&
        (!('assignedRiderId' in data.keys()) || data.assignedRiderId == null || (data.assignedRiderId is string && data.assignedRiderId.size() <= 128)) &&
        data.rideOtp is string && data.rideOtp.size() <= 10 &&
        data.createdAt is number;
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
  }
}
