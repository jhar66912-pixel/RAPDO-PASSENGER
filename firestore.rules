rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin function to check if user has admin role
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Users: Only owner can read/write profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Wallet: Only owner can access wallet.
    match /users/{userId}/wallet/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Rides: Only ride owner and assigned captain can access.
    match /rides/{rideId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         resource.data.captainId == request.auth.uid || 
         isAdmin());
    }

    // Notifications: Only authenticated users.
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      // Only backend or admin can write
      allow write: if isAdmin();
    }
  }
}
